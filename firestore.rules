rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (Default Deny Catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Common global helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'meruvashanmugam9@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. User root documents
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // 3. User subcollections (Flat Rules)
    match /users/{userId}/rooms/{roomId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get, create, update, delete: if (isOwner(userId) || isAdmin()) && isValidId(roomId);
    }

    match /users/{userId}/guests/{guestId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get, create, update, delete: if (isOwner(userId) || isAdmin()) && isValidId(guestId);
    }

    match /users/{userId}/payments/{paymentId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get, create, update, delete: if (isOwner(userId) || isAdmin()) && isValidId(paymentId);
    }

    match /users/{userId}/deletedGuests/{deletedGuestId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get, create, update, delete: if (isOwner(userId) || isAdmin()) && isValidId(deletedGuestId);
    }

    match /users/{userId}/businessConfig/{configId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get, create, update, delete: if isOwner(userId) || isAdmin();
    }

    // 4. Global system configuration (Allow read for logged in users, write only for Platform Admin)
    match /system/{documentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
